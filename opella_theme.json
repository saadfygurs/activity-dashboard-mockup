{
  "name": "Opella — Cordata",
  "dataColors": [
    "#1C7C3E",
    "#48BA6B",
    "#135A2B",
    "#7FB2C4",
    "#59626D",
    "#B9740A",
    "#C0392B",
    "#C9CFD5"
  ],
  "foreground": "#1B1F24",
  "foregroundNeutralSecondary": "#59626D",
  "foregroundNeutralTertiary": "#8B939D",
  "background": "#FFFFFF",
  "backgroundLight": "#EEF1F3",
  "backgroundNeutral": "#E3E6EA",
  "tableAccent": "#1C7C3E",
  "good": "#1E8E5A",
  "neutral": "#8B939D",
  "bad": "#C0392B",
  "maximum": "#1C7C3E",
  "center": "#E3E6EA",
  "minimum": "#C0392B",
  "null": "#F1F3F5",
  "hyperlink": "#135A2B",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 13,
      "color": "#1B1F24"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1B1F24"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#59626D"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 38,
      "color": "#1B1F24"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E3E6EA"
              }
            },
            "radius": 8
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "preset": "Custom",
            "color": {
              "solid": {
                "color": "#101820"
              }
            },
            "position": "Outer",
            "angle": 90,
            "distance": 2,
            "blur": 6,
            "spread": 0,
            "transparency": 88
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1B1F24"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "alignment": "left",
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "foreground": {
              "solid": {
                "color": "#8B939D"
              }
            },
            "border": {
              "solid": {
                "color": "#E3E6EA"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#ECEFF1"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#DFE3E7"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#1B1F24"
              }
            },
            "fontSize": 32,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#8B939D"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#CBD1D7"
              }
            },
            "radius": 3
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": {
              "solid": {
                "color": "#EDEFF2"
              }
            },
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#EDEFF2"
              }
            },
            "outlineColor": {
              "solid": {
                "color": "#E3E6EA"
              }
            },
            "rowPadding": 4
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#59626D"
              }
            },
            "backColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 9
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": {
              "solid": {
                "color": "#EDEFF2"
              }
            },
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#EDEFF2"
              }
            },
            "outlineColor": {
              "solid": {
                "color": "#E3E6EA"
              }
            }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#59626D"
              }
            },
            "backColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 9
          }
        ]
      }
    }
  }
}